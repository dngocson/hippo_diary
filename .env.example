# API Configuration
# Copy file này thành .env và cập nhật các giá trị

# Base URL cho API backend
# Development (local): http://localhost:3000/api
# Development (network): http://192.168.1.x:3000/api (thay IP của máy bạn)
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Supabase Configuration (nếu sử dụng)
# Lấy từ: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
EXPO_PUBLIC_APP_NAME=Hippo Diary
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_DEBUG=true
